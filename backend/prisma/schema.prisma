generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  industry  String?
  createdAt DateTime @default(now())
  workflows Workflow[]
  progress  Progress[]
  purchases Purchase[]
}

model Workflow {
  id          String   @id @default(cuid())
  description String
  tasks       Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
}

model Agent {
  id           String     @id @default(cuid())
  name         String
  category     String
  description  String
  price        String
  affiliateUrl String
  commission   Float
  purchases    Purchase[]
}

model Purchase {
  id        String   @id @default(cuid())
  status    String   @default("clicked")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  agent     Agent    @relation(fields: [agentId], references: [id])
  agentId   String
}

model Progress {
  id          String   @id @default(cuid())
  lessonId    String
  xp          Int      @default(0)
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
}
